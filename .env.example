# Speculus CLI configuration
#
# Setup:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Replace the placeholder below with your real Speculus API token.
#      Tokens are issued from your Speculus dashboard and look like:
#        spec_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#   3. Save the file. The CLI loads .env automatically on startup.
#

SPECULUS_TOKEN=your_speculus_api_token_here
